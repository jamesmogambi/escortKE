// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Agencies
    match /agencies/{agencyId} {
      allow read: if true;
      allow write: if request.auth != null &&
        (request.auth.uid == resource.data.ownerId ||
         request.auth.token.admin == true);
    }

    // Escorts (can be independent or agency-owned)
    match /escorts/{escortId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (
        // Independent escorts can update themselves
        request.auth.uid == resource.data.userId ||
        // Agency owners can update their escorts
        (resource.data.isAgencyOwned == true &&
         get(/databases/$(database)/documents/agencies/$(resource.data.agencyId)).data.ownerId == request.auth.uid) ||
        // Admin can update anything
        request.auth.token.admin == true
      );
    }
  }
}
